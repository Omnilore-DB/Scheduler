# ----------------------------------------------------------------------------
# Omnilore Scheduler — environment template
# ----------------------------------------------------------------------------
# The application itself is a client-side Flutter web app. It does NOT read a
# .env file at runtime. Every variable below is consumed exclusively by the
# GitHub Actions deployment workflow (.github/workflows/deploy.yml) and must
# be configured as a GitHub repository secret, NOT committed here.
#
# To set these values:
#   GitHub repo  →  Settings  →  Secrets and variables  →  Actions  →  New
#
# Never paste real credentials into this file or any file in the repository.
# ----------------------------------------------------------------------------

# --- AWS credentials (deploy IAM user/role) ----------------------------------

# AWS access key ID for the deploy user.
# Used by aws-actions/configure-aws-credentials@v4 in deploy.yml.
# Rotation: see Operations_Runbook.md §Key Rotation.
AWS_ACCESS_KEY_ID=

# AWS secret access key paired with the key above.
AWS_SECRET_ACCESS_KEY=

# AWS region containing the EC2 host and security group, e.g. us-west-2.
AWS_REGION=

# --- AWS networking ----------------------------------------------------------

# EC2 security group ID (e.g. sg-0abc123…). The deploy job temporarily adds
# the GitHub runner's public IPv4 to allow port-22 SSH, then revokes it in
# the final step (revoke runs even if a previous step fails).
AWS_SG_ID=

# --- EC2 host targeted by SCP ------------------------------------------------

# Public DNS name or IP address of the EC2 instance that serves the build.
# Today this maps to scheduler.omnilore.org.
EC2_HOST=

# SSH login user on the EC2 instance (commonly ubuntu or ec2-user).
EC2_USERNAME=

# Private SSH key (full PEM contents, including -----BEGIN/-----END lines).
# This is the most sensitive value here — rotate first if there is any doubt
# about exposure. The corresponding public key must be in
# ~/.ssh/authorized_keys for EC2_USERNAME on EC2_HOST.
EC2_SSH_KEY=

# ----------------------------------------------------------------------------
# Quotas, expirations, and ownership are tracked in Operations_Runbook.md
# §Expiration and Deactivation Dates. Keep that table current whenever a
# credential is rotated or a service is renewed.
# ----------------------------------------------------------------------------
